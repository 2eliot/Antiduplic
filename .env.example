APP_ENV=production
APP_HOST=127.0.0.1
APP_PORT=8000
SESSION_HTTPS_ONLY=true

DATABASE_URL=postgresql+pg8000://antiduplic:change-me-db-password@127.0.0.1:5432/antiduplic
SECRET_KEY=replace-with-a-long-random-secret

SEED_DEMO_DATA=false
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_FULL_NAME=Administrador Antiduplic
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=replace-with-a-strong-admin-password
INITIAL_ADMIN_TIMEZONE=America/Caracas

GUNICORN_WORKERS=2
GUNICORN_TIMEOUT=60

POSTGRES_DB=antiduplic
POSTGRES_USER=antiduplic
POSTGRES_PASSWORD=replace-with-a-strong-postgres-password
POSTGRES_PORT=5432
POSTGRES_CONTAINER_NAME=antiduplic-postgres
